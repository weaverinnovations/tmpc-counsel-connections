# Clerk Authentication
# In development, Clerk runs in "keyless mode" — keys are auto-generated.
# These are OPTIONAL for local dev. Required for production deployment.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
# CLERK_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host.neon.tech/tmpc_counsel_connections?sslmode=require

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
